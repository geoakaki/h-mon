        <!-- ==================== NOTES ==================== -->
        <mxCell id="notes" value="&lt;font style=&quot;font-size:8px&quot;&gt;&lt;b&gt;NOTES:&lt;/b&gt;&lt;br&gt;1. All electrical work must be performed by a qualified electrician&lt;br&gt;2. CAT5-FTP (shielded) cable for all thermostat connections — shield drain to earth at UH8-N&lt;br&gt;3. Bathrooms are NOT on manifold — towel rails plumbed directly to heating circuit with manual TRVs&lt;br&gt;4. Studio floor sensor (10k NTC) connects to neoStat RT1/RT2 to limit floor temperature&lt;br&gt;5. DHW combi operates on demand — H Water zone provides on/off scheduling via neoHub&lt;br&gt;6. Heating boiler fires when any zone 1-4 calls for heat (via Heat Enable volt-free contact)&lt;/font&gt;" style="text;html=1;align=left;verticalAlign=top;rounded=1;fillColor=#FFFDE7;strokeColor=#F9A825;spacing=8;fontSize=8;fontColor=#555;" vertex="1" parent="1">
          <mxGeometry x="100" y="1060" width="690" height="90" as="geometry" />
        </mxCell>

