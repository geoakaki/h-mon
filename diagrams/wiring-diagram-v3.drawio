        <mxCell id="ztc" value="&lt;table style=&quot;font-size:9px;border-collapse:collapse;&quot;&gt;&lt;tr style=&quot;font-weight:bold;border-bottom:1px solid #ccc;&quot;&gt;&lt;td style=&quot;padding:2px 6px;&quot;&gt;Zone&lt;/td&gt;&lt;td style=&quot;padding:2px 6px;&quot;&gt;Room&lt;/td&gt;&lt;td style=&quot;padding:2px 6px;&quot;&gt;Type&lt;/td&gt;&lt;td style=&quot;padding:2px 6px;&quot;&gt;Control&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding:2px 6px;&quot;&gt;1&lt;/td&gt;&lt;td style=&quot;padding:2px 6px;&quot;&gt;Bedroom 1&lt;/td&gt;&lt;td style=&quot;padding:2px 6px;&quot;&gt;Radiator&lt;/td&gt;&lt;td style=&quot;padding:2px 6px;&quot;&gt;neoStat 12V&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding:2px 6px;&quot;&gt;2&lt;/td&gt;&lt;td style=&quot;padding:2px 6px;&quot;&gt;Bedroom 2&lt;/td&gt;&lt;td style=&quot;padding:2px 6px;&quot;&gt;Radiator&lt;/td&gt;&lt;td style=&quot;padding:2px 6px;&quot;&gt;neoStat 12V&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&quot;padding:2px 6px;&quot;&gt;3&lt;/td&gt;&lt;td style=&quot;padding:2px 6px;&quot;&gt;Bedroom 3&lt;/td&gt;&lt;td style=&quot;padding:2px 6px;&quot;&gt;Radiator&lt;/td&gt;&lt;td style=&quot;padding:2px 6px;&quot;&gt;neoStat 12V&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;color:#2E7D32;&quot;&gt;&lt;td style=&quot;padding:2px 6px;&quot;&gt;4&lt;/td&gt;&lt;td style=&quot;padding:2px 6px;&quot;&gt;Studio&lt;/td&gt;&lt;td style=&quot;padding:2px 6px;&quot;&gt;UFH&lt;/td&gt;&lt;td style=&quot;padding:2px 6px;&quot;&gt;neoStat 12V + Floor Sensor&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;color:#aaa;&quot;&gt;&lt;td style=&quot;padding:2px 6px;&quot;&gt;5-8&lt;/td&gt;&lt;td style=&quot;padding:2px 6px;&quot;&gt;—&lt;/td&gt;&lt;td style=&quot;padding:2px 6px;&quot;&gt;Unused&lt;/td&gt;&lt;td style=&quot;padding:2px 6px;&quot;&gt;—&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;color:#F57F17;&quot;&gt;&lt;td style=&quot;padding:2px 6px;&quot;&gt;—&lt;/td&gt;&lt;td style=&quot;padding:2px 6px;&quot;&gt;Bath 1 &amp;amp; 2&lt;/td&gt;&lt;td style=&quot;padding:2px 6px;&quot;&gt;Towel Rail&lt;/td&gt;&lt;td style=&quot;padding:2px 6px;&quot;&gt;Manual TRV (no UH8-N zone)&lt;/td&gt;&lt;/tr&gt;&lt;tr style=&quot;color:#0277BD;&quot;&gt;&lt;td style=&quot;padding:2px 6px;&quot;&gt;HW&lt;/td&gt;&lt;td style=&quot;padding:2px 6px;&quot;&gt;—&lt;/td&gt;&lt;td style=&quot;padding:2px 6px;&quot;&gt;DHW&lt;/td&gt;&lt;td style=&quot;padding:2px 6px;&quot;&gt;neoStat 12V (timer)&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="text;html=1;align=left;verticalAlign=top;fontSize=9;" vertex="1" parent="1">
